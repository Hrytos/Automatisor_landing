<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content="<%= description %>" />
<title><%= title %></title>
<link rel="icon" type="image/png" href="/assets/headerlogo.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Nunito:wght@300;400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/css/main.css" />
<style>
  .schedule-hero {
    padding: 140px 0 60px;
    text-align: center;
  }
  .schedule-hero .hero-badge {
    justify-content: center;
    margin-bottom: 24px;
  }
  .schedule-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 16px;
  }
  .schedule-hero p {
    font-family: var(--font-secondary);
    color: var(--color-text-muted);
    font-size: 1.1rem;
    max-width: 560px;
    margin: 0 auto;
  }
  .scheduler-wrapper {
    padding: 0 0 80px;
  }
  .scheduler-frame-container {
    max-width: 900px;
    margin: 0 auto;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .meetings-iframe-container iframe {
    width: 100% !important;
    border: none !important;
  }
</style>
</head>
<body>

<!-- ═══════════════════════ NAV ═══════════════════════ -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <img src="/assets/Automatisor_Logo_light.png" alt="Hrytos" onerror="this.style.display='none'" />
    </a>
    <!-- Commenting out the menu links
    <ul class="nav-links">
      <li><a href="/#position">Approach</a></li>
      <li><a href="/#problem">Problem</a></li>
      <li><a href="/#how-it-works">Intelligence</a></li>
      <li><a href="/#processes">Processes</a></li>
      <li><a href="/#industries">Industries</a></li>
    </ul>
  -->
    <div class="nav-ctas">
      <a href="/schedule" class="btn-nav-filled">Start your Assessment</a>
    </div>
    <button class="nav-hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <!-- Commenting out the menu links
  <div class="mobile-menu" id="mobileMenu">
    <a href="/#position">Approach</a>
    <a href="/#problem">Problem</a>
    <a href="/#how-it-works">Intelligence</a>
    <a href="/#processes">Processes</a>
    <a href="/#industries">Industries</a>
    <div class="mobile-menu-ctas">
      <a href="/schedule" class="btn-nav-filled" style="text-align:center;display:block;padding:12px 0;border-radius:100px;">Start your Assessment</a>
    </div>
  </div>
-->
</nav>

<!-- ═══════════════════════ SCHEDULE HERO ═══════════════════════ -->
<section class="schedule-hero">
  <div class="container">
    <div class="hero-badge">
      <div class="hero-badge-dot"></div>
      <span>Decision Intelligence for Intrlagistics Automation</span>
      <div class="hero-badge-dot"></div>
    </div>
    <h1 class="hero-h1">Schedule your <span class="line-amber">Facility Assessment</span></h1>
    <p class="hero-sub">Book a session with Automatisor - the Automation Advisor for Intralogistics. We'll assess your operations, diagnose your needs, and chart your right-fit automation path.</p>
  </div>
</section>

<!-- ═══════════════════════ HUBSPOT SCHEDULER ═══════════════════════ -->
<section class="scheduler-wrapper">
  <div class="container">
    <div class="scheduler-frame-container">
      <div class="meetings-iframe-container" data-src="https://meetings-na2.hubspot.com/hrytos?embed=true"></div>
      <script type="text/javascript" src="https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js"></script>
    </div>
  </div>
</section>

<!-- ═══════════════════════ FOOTER ═══════════════════════ -->
<footer id="about">
  <div class="container">
    <div class="footer-top">
      <div>
        <div class="footer-brand-name">
          <img src="/assets/Automatisor_Logo_light.png" alt="Hrytos" onerror="this.style.display='none'" />
        </div>
        <div class="footer-tagline">Decision Intelligence for Intralogistics Automation</div>
      </div>
      <div class="footer-links-grid">
        <div>
          <div class="footer-col-title">By industry</div>
          <ul class="footer-col-links">
            <li><a href="#">Warehousing</a></li>
            <li><a href="#">Manufacturing</a></li>
            <li><a href="#">Fulfilment centers</a></li>
            <li><a href="#">Distribution centers</a></li>
          </ul>
        </div>
        <div>
          <div class="footer-col-title">By process</div>
          <ul class="footer-col-links">
            <li><a href="#">Inbound receiving</a></li>
            <li><a href="#">Outbound staging</a></li>
            <li><a href="#">Line-side replenishment</a></li>
            <li><a href="#">Cross-docking</a></li>
          </ul>
        </div>
        <div>
          <div class="footer-col-title">Resources</div>
          <ul class="footer-col-links">
            <li><a href="https://hrytos.substack.com">Blog</a></li>
            <li><a href="#">University</a></li>
            <li><a href="#">Community</a></li>
            <li><a href="#">Events &amp; webinars</a></li>
          </ul>
        </div>
        <div>
          <div class="footer-col-title">Company</div>
          <ul class="footer-col-links">
            <li><a href="#">About</a></li>
            <li><a href="#">Team</a></li>
            <li><a href="https://wellfound.com/company/hrytos">Careers</a></li>
            <li><a href="#">Newsroom</a></li>
          </ul>
        </div>
        <div>
          <div class="footer-col-title">Social</div>
          <ul class="footer-col-links">
            <li><a href="https://linkedin.com/company/automatisor">LinkedIn</a></li>
            <li><a href="https://www.youtube.com/@automatisor">YouTube</a></li>
            <li><a href="https://instagram.com/hrytos">Instagram</a></li>
            <li><a href="https://x.com/hrytos">X</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-copy">© 2026 Hrytos, Inc. All rights reserved.</div>
      <div class="footer-legal">
        <a href="#">Privacy policy</a>
        <a href="#">Terms of service</a>
      </div>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
